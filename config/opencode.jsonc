{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": true,
    "mdnsDomain": "myproject.local",
    "cors": ["http://localhost:5173"],
  },
  "provider": {
    "opencode-go": {
      "name": "opencode-go",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "apiKey": "<PLACEHOLDER_OPENCODE_GO_API_KEY>",
      },
      "models": {
        "glm-5.2": { "name": "glm-5.2", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "glm-5.1": { "name": "glm-5.1", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "kimi-k2.7": { "name": "kimi-k2.7", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "kimi-k2.7-code": { "name": "kimi-k2.7-code", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "kimi-k2.6": { "name": "kimi-k2.6", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "deepseek-v4-pro": { "name": "deepseek-v4-pro", "reasoning": true, "options": { "reasoningEffort": "max" } },
        "deepseek-v4-flash": { "name": "deepseek-v4-flash", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "mimo-v2.5": {
          "name": "mimo-v2.5",
          "reasoning": true,
          "options": { "reasoningEffort": "high" },
          "variants": {
            "max": { "options": { "reasoningEffort": "high" } },
            "high": { "options": { "reasoningEffort": "high" } },
            "low": { "options": { "reasoningEffort": "low" } }
          }
        },
        "mimo-v2.5-pro": {
          "name": "mimo-v2.5-pro",
          "reasoning": true,
          "options": { "reasoningEffort": "high" },
          "variants": {
            "max": { "options": { "reasoningEffort": "high" } },
            "high": { "options": { "reasoningEffort": "high" } },
            "low": { "options": { "reasoningEffort": "low" } }
          }
        },
        "minimax-m3": { "name": "minimax-m3", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "minimax-m2.7": { "name": "minimax-m2.7", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "minimax-m2.5": { "name": "minimax-m2.5", "reasoning": true, "options": { "reasoningEffort": "high" } },
      },
    },
    "opencode-go1": {
      "name": "opencode-go1",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "apiKey": "<PLACEHOLDER_OPENCODE_GO1_API_KEY>",
      },
      "models": {
        "glm-5.2": { "name": "glm-5.2", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "glm-5.1": { "name": "glm-5.1", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "kimi-k2.7": { "name": "kimi-k2.7", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "kimi-k2.7-code": { "name": "kimi-k2.7-code", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "kimi-k2.6": { "name": "kimi-k2.6", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "deepseek-v4-pro": { "name": "deepseek-v4-pro", "reasoning": true, "options": { "reasoningEffort": "max" } },
        "deepseek-v4-flash": { "name": "deepseek-v4-flash", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "mimo-v2.5": { "name": "mimo-v2.5", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "mimo-v2.5-pro": { "name": "mimo-v2.5-pro", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "minimax-m3": { "name": "minimax-m3", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "minimax-m2.7": { "name": "minimax-m2.7", "reasoning": true, "options": { "reasoningEffort": "high" } },
        "minimax-m2.5": { "name": "minimax-m2.5", "reasoning": true, "options": { "reasoningEffort": "high" } },
      },
    },
    "opencode-go-anthropic": {
      "name": "opencode-go-anthropic",
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "apiKey": "<PLACEHOLDER_OPENCODE_GO_API_KEY>",
      },
      "models": {
        "qwen3.7-max": { "name": "qwen3.7-max" },
        "qwen3.7-plus": { "name": "qwen3.7-plus" },
        "qwen3.6-plus": { "name": "qwen3.6-plus" },
      },
    },
    "opencode-free": {
      "name": "opencode-free",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://opencode.ai/zen/go/v1",
        "apiKey": "<PLACEHOLDER_OPENCODE_FREE_API_KEY>",
      },
      "models": {
        "big-pickle": { "name": "big-pickle" },
        "deepseek-v4-flash-free": { "name": "deepseek-v4-flash-free" },
        "mimo-v2.5-free": { "name": "mimo-v2.5-free" },
        "north-mini-code-free": { "name": "north-mini-code-free" },
        "nemotron-3-ultra-free": { "name": "nemotron-3-ultra-free" },
      },
    },
  },
  "plugin": [
    "oh-my-opencode-slim",
    "context-mode",
    "opencode-token-monitor@latest",
    "@dietrichgebert/ponytail",
    "./plugins/caveman/plugin.js",
    "./plugins/worktree/worktree.ts",
  ],
  "agent": {
    "explore": { "disable": true },
    "general": { "disable": true },
  },
  "mcp": {
    "codebase-memory-mcp": {
      "enabled": true,
      "type": "local",
      "command": ["bash", "-l", "-c", "codebase-memory-mcp"],
      "timeout": 60000,
    },
    "agentmemory": {
      "enabled": true,
      "type": "local",
      "command": ["bash", "-l", "-c", "agentmemory mcp"],
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["bash", "-l", "-c", "npx -y chrome-devtools-mcp@latest --no-usage-statistics --no-performance-crux --slim"],
    },
    "markitdown": {
      "type": "local",
      "command": ["bash", "-l", "-c", "markitdown-mcp"],
    },
    "sequential-thinking": {
      "enabled": true,
      "type": "local",
      "command": ["bash", "-l", "-c", "npx -y @modelcontextprotocol/server-sequential-thinking"],
    },
    "github": {
      "type": "local",
      "command": ["bash", "-l", "-c", "npx -y @modelcontextprotocol/server-github"],
    },
    "deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
    },
  },
  "lsp": true,
}
